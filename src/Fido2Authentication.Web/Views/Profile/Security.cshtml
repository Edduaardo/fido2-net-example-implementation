@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Security settings";
}

<div class="d-flex">
    <div class="me-auto">
        <h5>Change password</h5>
    </div>
</div>
<div class="card">
    <div class="card-body">
        <form asp-action="ChangePassword" id="change-password-form" novalidate>
            <div class="row g-3 align-items-center">
                <div class="col-3">
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label" max-length="16">Current password</label>
                        <input asp-for="CurrentPassword" type="password" id="currentPassword" class="form-control" required>
                        @* <div class="invalid-feedback">This field is not optional.</div> *@
                        <span class="text-danger" asp-validation-for="CurrentPassword"></span>
                    </div>
                </div>
                <div class="col-3">
                    <div class="mb-3">
                        <label for="newPassword" class="form-label" max-length="16">New password</label>
                        <input asp-for="NewPassword" type="password" id="newPassword" class="form-control" required>
                        @* <div class="invalid-feedback">This field is not optional.</div> *@
                        <span class="text-danger" asp-validation-for="NewPassword"></span>
                    </div>
                </div>
                <div class="col-3">
                    <div class="mb-3">
                        <label for="confimNewPassword" class="form-label" max-length="16">Confirm new password</label>
                        <input asp-for="ConfirmNewPassword" type="password" id="confimNewPassword" class="form-control" required>
                        @* <div class="invalid-feedback">This field is not optional.</div> *@
                        <span class="text-danger" asp-validation-for="ConfirmNewPassword"></span>
                    </div>
                </div>
                <div class="col-auto mb-3 align-self-end">
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>          
    </div>
</div>
<div class="d-flex mt-3">
    <div class="me-auto">
        <h5>Your passkeys</h5>
    </div>
    <div>
        <a id="add-passkey" href="#"><i class="bi bi-plus"></i> Add a passkey</a>
    </div>
</div>
<div class="card overflow-hidden">
    <div class="card-body">
        <div class="row">
            <div class="col">
                <div class="card-body">
                    <table id="user-passkeys-table" class="table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Date created</th>
                                <th>Options</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/helpers/base64.js"></script>
    <script src="~/js/pages/security.js"></script>
}
